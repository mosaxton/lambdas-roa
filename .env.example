# Local development environment variables for `sam local invoke`.
# Copy to .env.local and fill in values. Never commit .env.local.
#
# scripts/invoke-local.sh auto-converts .env.local → .env.local.json
# in the correct SAM env-vars format. Just run: make invoke FN=... EVENT=...

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Postgres spun up by `make db-up`
DATABASE_URL=postgresql://roa:roa@localhost:5433/roa_lambdas_dev?sslmode=disable

# ── Encryption ────────────────────────────────────────────────────────────────
# 64 hex chars = 32 bytes. Use a randomly generated dev key; NEVER use prod key locally.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=FILL_IN_64_HEX_CHARS

# ── AWS Secrets Manager (for local dev, these are read directly from env) ─────
# When running locally, shared/secrets.py falls back to env vars if Secrets Manager fails.
DATABASE_URL_SECRET_NAME=roa/database-url
ENCRYPTION_KEY_SECRET_NAME=roa/encryption-key
BB_CLIENT_ID_SECRET_NAME=roa/bb-client-id
BB_CLIENT_SECRET_SECRET_NAME=roa/bb-client-secret
SLACK_WEBHOOK_SECRET_NAME=roa/slack-webhook-url

# ── CMS Blue Button Sandbox ───────────────────────────────────────────────────
# Get sandbox creds at https://sandbox.bluebutton.cms.gov/developers
BB_BASE_URL=https://sandbox.bluebutton.cms.gov
BB_CLIENT_ID=FILL_IN
BB_CLIENT_SECRET=FILL_IN

# ── Slack Alerts ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=FILL_IN_SLACK_INCOMING_WEBHOOK_URL

# ── NPPES ─────────────────────────────────────────────────────────────────────
NPPES_API_URL=https://npiregistry.cms.hhs.gov/api/
NPPES_CACHE_TTL_HOURS=168

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
